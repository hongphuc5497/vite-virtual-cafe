{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-ops.local/schema/handoff.schema.json",
  "title": "Agent Ops Handoff",
  "type": "object",
  "required": ["from", "to", "task_id", "files", "acceptance", "created_at"],
  "properties": {
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "verification": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

